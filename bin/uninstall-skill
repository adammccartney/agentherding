#!/usr/bin/env bash
#
# Uninstall a pi skill (remove symlink)
#
# Usage: ./bin/uninstall-skill <skill-name>
#
# Example:
#   ./bin/uninstall-skill commit
#

set -euo pipefail

SKILL_NAME="${1:-}"

if [[ -z "$SKILL_NAME" ]]; then
    echo "Usage: $0 <skill-name>" >&2
    echo "" >&2
    echo "Installed skills:" >&2
    if [[ -d "$HOME/.pi/agent/skills" ]]; then
        for skill in "$HOME/.pi/agent/skills"/*/; do
            if [[ -L "$skill" ]]; then
                echo "  - $(basename "$skill") (symlink)" >&2
            elif [[ -d "$skill" ]]; then
                echo "  - $(basename "$skill") (copy)" >&2
            fi
        done
    fi
    exit 1
fi

TARGET="$HOME/.pi/agent/skills/$SKILL_NAME"

if [[ ! -e "$TARGET" ]]; then
    echo "Error: Skill '$SKILL_NAME' is not installed" >&2
    exit 1
fi

if [[ -L "$TARGET" ]]; then
    rm -v "$TARGET"
    echo ""
    echo "✓ Symlink removed"
elif [[ -d "$TARGET" ]]; then
    echo "Warning: '$TARGET' is a copy, not a symlink" >&2
    read -p "Remove it anyway? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rv "$TARGET"
        echo ""
        echo "✓ Skill removed"
    else
        echo "Cancelled"
        exit 0
    fi
fi

echo ""
echo "Reload in pi with: /reload"
