#!/usr/bin/env bash
#
# Uninstall a pi skill (remove copied directory)
#
# Usage: ./bin/uninstall-skill <skill-name>
#
# Example:
#   ./bin/uninstall-skill commit
#

set -euo pipefail

SKILL_NAME="${1:-}"

if [[ -z "$SKILL_NAME" ]]; then
    echo "Usage: $0 <skill-name>" >&2
    echo "" >&2
    echo "Installed skills:" >&2
    if [[ -d "$HOME/.pi/agent/skills" ]]; then
        for skill in "$HOME/.pi/agent/skills"/*/; do
            if [[ -d "$skill" ]]; then
                echo "  - $(basename "$skill")" >&2
            fi
        done
    fi
    exit 1
fi

TARGET="$HOME/.pi/agent/skills/$SKILL_NAME"

if [[ ! -d "$TARGET" ]]; then
    echo "Error: Skill '$SKILL_NAME' is not installed" >&2
    exit 1
fi

rm -rv "$TARGET"
echo ""
echo "✓ Skill removed"

echo ""
echo "Reload in pi with: /reload"
