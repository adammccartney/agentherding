#!/usr/bin/env bash
#
# Uninstall a pi extension (remove copied directory)
#
# Usage: ./bin/uninstall-extension <extension-name>
#
# Example:
#   ./bin/uninstall-extension sandbox-workflow
#

set -euo pipefail

EXT_NAME="${1:-}"

if [[ -z "$EXT_NAME" ]]; then
    echo "Usage: $0 <extension-name>" >&2
    echo "" >&2
    echo "Installed extensions:" >&2
    if [[ -d "$HOME/.pi/agent/extensions" ]]; then
        for ext in "$HOME/.pi/agent/extensions"/*/; do
            if [[ -d "$ext" ]]; then
                echo "  - $(basename "$ext")" >&2
            fi
        done
    fi
    exit 1
fi

TARGET="$HOME/.pi/agent/extensions/$EXT_NAME"

if [[ ! -d "$TARGET" ]]; then
    echo "Error: Extension '$EXT_NAME' is not installed" >&2
    exit 1
fi

rm -rv "$TARGET"
echo ""
echo "✓ Extension removed"

echo ""
echo "Reload in pi with: /reload"
