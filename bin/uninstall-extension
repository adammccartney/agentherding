#!/usr/bin/env bash
#
# Uninstall a pi extension (remove symlink)
#
# Usage: ./bin/uninstall-extension <extension-name>
#
# Example:
#   ./bin/uninstall-extension sandbox-workflow
#

set -euo pipefail

EXT_NAME="${1:-}"

if [[ -z "$EXT_NAME" ]]; then
    echo "Usage: $0 <extension-name>" >&2
    echo "" >&2
    echo "Installed extensions:" >&2
    if [[ -d "$HOME/.pi/agent/extensions" ]]; then
        for ext in "$HOME/.pi/agent/extensions"/*/; do
            if [[ -L "$ext" ]]; then
                echo "  - $(basename "$ext") (symlink)" >&2
            elif [[ -d "$ext" ]]; then
                echo "  - $(basename "$ext") (copy)" >&2
            fi
        done
    fi
    exit 1
fi

TARGET="$HOME/.pi/agent/extensions/$EXT_NAME"

if [[ ! -e "$TARGET" ]]; then
    echo "Error: Extension '$EXT_NAME' is not installed" >&2
    exit 1
fi

if [[ -L "$TARGET" ]]; then
    rm -v "$TARGET"
    echo ""
    echo "✓ Symlink removed"
elif [[ -d "$TARGET" ]]; then
    echo "Warning: '$TARGET' is a copy, not a symlink" >&2
    read -p "Remove it anyway? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rv "$TARGET"
        echo ""
        echo "✓ Extension removed"
    else
        echo "Cancelled"
        exit 0
    fi
fi

echo ""
echo "Reload in pi with: /reload"
