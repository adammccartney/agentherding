# Pi Docker Configuration Template
# Copy this file to .env and customize for your workflow
# 
# Security: This file may contain sensitive paths - keep it local!

#==============================================================================
# Pi Configuration
#==============================================================================

# Pi config directory is always ~/.pi/agent (where your auth/models/settings live)
# Extensions and skills can be symlinked to version-controlled directories
# The script automatically detects and mounts symlinked repos

#==============================================================================
# Sandbox Workflow Configuration
#==============================================================================

# Base directory for sandbox projects on the HOST
# The sandbox-workflow extension creates sandboxes here
SANDBOX_BASE_HOST=~/src/sandbox

# Base directory for sandbox projects in the CONTAINER
# Should match the pi user's home structure
SANDBOX_BASE_CONTAINER=/home/node/src/sandbox

# Path to the original repository (for /sandbox:sync)
# Leave empty if not using sandbox workflow
# Example: ORIGINAL_REPO_PATH=~/src/gitlab.com/ansible-rke2
ORIGINAL_REPO_PATH=

#==============================================================================
# Custom Mounts (Optional)
#==============================================================================

# Additional directory to mount (e.g., shared code, custom extensions)
# Leave empty if not needed
CUSTOM_PATH=

#==============================================================================
# Working Directory (Docker Compose only)
#==============================================================================

# Override the working directory inside the container
# Usually auto-detected by docker-pi.sh, but can be set for docker-compose
# WORKDIR=/home/node/src/sandbox/my-project
