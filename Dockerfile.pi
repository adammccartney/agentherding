# Dockerfile for running pi coding agent in a container
#
# Security: Runs as non-root user matching host UID/GID
#
# Usage:
#   # Build (uses your host UID/GID by default)
#   docker build -f Dockerfile.pi -t pi-agent .
#
#   # Or with custom UID/GID
#   docker build --build-arg HOST_UID=$(id -u) --build-arg HOST_GID=$(id -g) -f Dockerfile.pi -t pi-agent .
#
#   # Or with other providers
#   docker run -it --rm \
#     -v ~/.pi/agent:/home/node/.pi/agent \
#     -v $(pwd):/workspace \
#     -w /workspace \
#     -e OPENAI_API_KEY \
#     pi-agent

FROM node:22-slim

# UID/GID for the non-root user (match your host user)
ARG HOST_UID=1000
ARG HOST_GID=1000

# Install any system dependencies pi might need
RUN apt-get update && apt-get install -y \
    git \
    curl \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Use the existing 'node' user and adjust UID/GID to match host
# The node:22-slim image already has a 'node' user with UID 1000
# We modify it to match the host UID/GID for proper volume permissions
RUN groupmod -g $HOST_GID node && \
    usermod -u $HOST_UID -g $HOST_GID node

# Install pi globally
RUN npm install -g @mariozechner/pi-coding-agent

# Set working directory
WORKDIR /workspace

# Switch to non-root user
USER node

# Copy entrypoint script
COPY --chown=node:node docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Set entrypoint and default command
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD []
